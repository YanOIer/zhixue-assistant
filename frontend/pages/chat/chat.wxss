.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

.chat-container {
  flex: 1;
  padding: 20rpx;
}

.message-list {
  padding-bottom: 20rpx;
}

.message {
  display: flex;
  margin-bottom: 30rpx;
  align-items: flex-start;
}

.message.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.message.user .avatar {
  background: #4A90E2;
}

.content {
  max-width: 70%;
  margin: 0 20rpx;
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  position: relative;
}

.message.user .content {
  background: #4A90E2;
  color: white;
}

.text {
  font-size: 30rpx;
  line-height: 1.6;
  word-break: break-all;
}

.sources {
  margin-top: 15rpx;
  padding-top: 15rpx;
  border-top: 1rpx solid #eee;
}

.message.user .sources {
  border-top-color: rgba(255,255,255,0.3);
}

.sources-title {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 10rpx;
}

.message.user .sources-title {
  color: rgba(255,255,255,0.7);
}

.source-item {
  font-size: 22rpx;
  color: #4A90E2;
  background: #f0f7ff;
  padding: 5rpx 15rpx;
  border-radius: 10rpx;
  margin-right: 10rpx;
  display: inline-block;
}

.loading-message {
  display: flex;
  margin-bottom: 30rpx;
  align-items: flex-start;
}

.loading-dots {
  display: flex;
  font-size: 40rpx;
  color: #999;
}

.loading-dots text {
  animation: dots 1.4s infinite ease-in-out both;
  margin: 0 4rpx;
}

.loading-dots text:nth-child(1) { animation-delay: -0.32s; }
.loading-dots text:nth-child(2) { animation-delay: -0.16s; }

@keyframes dots {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

.input-area {
  display: flex;
  padding: 20rpx;
  background: white;
  border-top: 1rpx solid #eee;
}

.message-input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 20rpx 30rpx;
  font-size: 30rpx;
}

.send-btn {
  width: 120rpx;
  margin-left: 20rpx;
  background: #4A90E2;
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.send-btn[disabled] {
  background: #ccc;
}
