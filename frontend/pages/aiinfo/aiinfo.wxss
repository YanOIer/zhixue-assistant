/** AI信息页样式 - 前卫极简科技风 **/

page {
  --primary: linear-gradient(135deg, #7c3aed 0%, #4f46e5 100%);
  --bg-dark: #09090b;
  --bg-card: rgba(24, 24, 27, 0.8);
  background: linear-gradient(160deg, #09090b 0%, #18181b 100%);
  min-height: 100vh;
}

.page {
  min-height: 100vh;
  padding: 24rpx 32rpx;
  padding-bottom: 60rpx;
}

/* 加载 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 3rpx solid rgba(124, 58, 237, 0.2);
  border-top-color: #7c3aed;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #52525b;
}

/* 系统状态卡片 */
.status-card {
  position: relative;
  background: linear-gradient(145deg, rgba(124, 58, 237, 0.12) 0%, rgba(59, 130, 246, 0.08) 100%);
  border: 1rpx solid rgba(124, 58, 237, 0.15);
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
}

.status-glow {
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(124, 58, 237, 0.2) 0%, transparent 70%);
  filter: blur(60rpx);
}

.status-title {
  position: relative;
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #fafafa;
  margin-bottom: 20rpx;
}

.run-mode-badge {
  display: inline-flex;
  padding: 10rpx 20rpx;
  background: rgba(124, 58, 237, 0.2);
  border: 1rpx solid rgba(124, 58, 237, 0.3);
  border-radius: 100rpx;
  margin-bottom: 16rpx;
}

.run-mode-badge text {
  font-size: 22rpx;
  color: #a78bfa;
  font-weight: 600;
}

.run-mode-desc {
  display: block;
  font-size: 24rpx;
  color: #71717a;
  line-height: 1.6;
}

/* 区块 */
.section {
  margin-bottom: 28rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

.section-icon-wrap {
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  font-size: 28rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #fafafa;
}

/* 卡片 */
.card {
  background: var(--bg-card);
  border: 1rpx solid rgba(255, 255, 255, 0.04);
  border-radius: 24rpx;
  padding: 28rpx;
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.info-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.info-row:first-child {
  padding-top: 0;
}

.row-label {
  font-size: 26rpx;
  color: #71717a;
}

.row-value {
  font-size: 26rpx;
  color: #a1a1aa;
  font-weight: 500;
}

.row-value.highlight-purple {
  color: #a78bfa;
}

.row-value.highlight-cyan {
  color: #22d3ee;
}

.row-status {
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
}

.row-status.online {
  color: #22c55e;
  background: rgba(34, 197, 94, 0.12);
}

.row-status.offline {
  color: #f87171;
  background: rgba(248, 113, 113, 0.12);
}

.row-status.warning {
  color: #fbbf24;
  background: rgba(251, 191, 36, 0.12);
}

/* 流程图 */
.flow-container {
  margin-bottom: 24rpx;
}

.flow-step {
  display: flex;
  align-items: flex-start;
}

.step-num {
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #4f46e5 100%);
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: white;
  flex-shrink: 0;
  margin-right: 18rpx;
}

.step-content {
  flex: 1;
  padding-top: 6rpx;
}

.step-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #fafafa;
  margin-bottom: 6rpx;
}

.step-desc {
  display: block;
  font-size: 24rpx;
  color: #52525b;
}

.flow-arrow {
  text-align: center;
  font-size: 32rpx;
  color: #3f3f46;
  padding: 16rpx 0;
  margin-left: 8rpx;
}

/* 提示框 */
.tip-box {
  margin-top: 20rpx;
  padding: 20rpx;
  background: rgba(124, 58, 237, 0.08);
  border-radius: 16rpx;
  border-left: 3rpx solid #7c3aed;
}

.tip-text {
  font-size: 24rpx;
  color: #71717a;
  line-height: 1.6;
}

/* 技术栈 */
.tech-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.tech-card {
  background: var(--bg-card);
  border: 1rpx solid rgba(255, 255, 255, 0.04);
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

.tech-layer {
  display: block;
  font-size: 20rpx;
  color: #52525b;
  margin-bottom: 8rpx;
}

.tech-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #a1a1aa;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 40rpx 0 20rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #27272a;
  letter-spacing: 2rpx;
}
