.container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  text-align: center;
  padding: 40rpx 0;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  margin-top: 10rpx;
  display: block;
}

.upload-section {
  margin: 40rpx 0;
}

.upload-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 60rpx;
  text-align: center;
  color: white;
}

.upload-icon {
  font-size: 80rpx;
  display: block;
}

.upload-text {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-top: 20rpx;
}

.upload-hint {
  font-size: 24rpx;
  opacity: 0.8;
  display: block;
  margin-top: 10rpx;
}

.quick-actions {
  display: flex;
  justify-content: space-around;
  margin: 40rpx 0;
}

.action-item {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
  width: 280rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.action-icon {
  font-size: 60rpx;
  display: block;
}

.action-text {
  font-size: 28rpx;
  color: #333;
  margin-top: 10rpx;
  display: block;
}

.recent-section {
  margin-top: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.file-list {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
}

.file-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.file-item:last-child {
  border-bottom: none;
}

.file-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.file-info {
  flex: 1;
}

.file-name {
  font-size: 30rpx;
  color: #333;
  display: block;
}

.file-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 5rpx;
  display: block;
}

/* 功能介绍 */
.feature-section {
  margin: 40rpx 0;
}

.feature-list {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 25rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-icon {
  font-size: 48rpx;
  margin-right: 25rpx;
  width: 60rpx;
  text-align: center;
}

.feature-info {
  flex: 1;
}

.feature-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.feature-desc {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
  display: block;
}

/* 技术信息 */
.tech-info {
  text-align: center;
  padding: 40rpx 0;
  margin-top: 20rpx;
}

.tech-text {
  font-size: 24rpx;
  color: #999;
}
