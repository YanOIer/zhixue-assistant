/** 全局样式 - 前卫极简科技风 **/
page {
  --primary: linear-gradient(135deg, #7c3aed 0%, #4f46e5 100%);
  --primary-solid: #7c3aed;
  --accent: #22d3ee;
  --bg-primary: #09090b;
  --bg-secondary: #18181b;
  --bg-card: rgba(24, 24, 27, 0.8);
  --text-primary: #fafafa;
  --text-secondary: #a1a1aa;
  --text-muted: #52525b;
  --border: rgba(255, 255, 255, 0.04);
  --shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
}

.container {
  padding: 30rpx;
  background: var(--bg-primary);
  min-height: 100vh;
}
