<view class="container">
  <!-- 状态指示器 -->
  <view class="status-bar {{backendReady ? 'online' : 'offline'}}">
    <view class="status-dot"></view>
    <text class="status-text">{{backendMode}}</text>
  </view>

  <!-- 核心区域 -->
  <view class="hero-section">
    <view class="hero-glow"></view>
    <text class="hero-title">智学助手</text>
    <text class="hero-subtitle">基于检索增强生成的智能学习伙伴</text>
  </view>

  <!-- 上传区域 -->
  <view class="upload-zone" bindtap="chooseMessageFile">
    <view class="upload-inner">
      <view class="upload-icon-wrap">
        <text class="upload-icon">↑</text>
      </view>
      <text class="upload-title">上传学习资料</text>
      <text class="upload-formats">PDF · TXT · DOCX · Markdown</text>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-grid">
    <view class="quick-item" bindtap="goToLibrary">
      <view class="quick-icon" style="background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%)">
        <text>📚</text>
      </view>
      <text class="quick-label">资料库</text>
    </view>
    <view class="quick-item" bindtap="goToChat">
      <view class="quick-icon" style="background: linear-gradient(135deg, #22d3ee 0%, #06b6d4 100%)">
        <text>💬</text>
      </view>
      <text class="quick-label">开始问答</text>
    </view>
    <view class="quick-item" bindtap="goToHistory">
      <view class="quick-icon" style="background: linear-gradient(135deg, #f472b6 0%, #ec4899 100%)">
        <text>📜</text>
      </view>
      <text class="quick-label">历史记录</text>
    </view>
  </view>

  <!-- 最近文件 -->
  <view class="recent-section" wx:if="{{recentFiles.length > 0}}">
    <text class="section-label">最近上传</text>
    <view class="recent-list">
      <view class="recent-item" wx:for="{{recentFiles}}" wx:key="id">
        <view class="recent-icon">
          <text>📄</text>
        </view>
        <view class="recent-info">
          <text class="recent-name">{{item.name}}</text>
          <text class="recent-meta">{{item.category}} · {{item.time}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <text class="footer-text">Powered by RAG + KIMI</text>
  </view>
</view>
