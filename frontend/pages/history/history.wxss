/** 历史记录页面样式 - 深色科技风格 **/

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0f172a 0%, #1e293b 100%);
  padding: 24rpx 32rpx;
  padding-bottom: 120rpx;
}

/* 顶部栏 */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #f1f5f9;
}

.clear-btn {
  font-size: 26rpx;
  color: #ef4444;
  padding: 10rpx 24rpx;
  background: rgba(239, 68, 68, 0.1);
  border-radius: 50rpx;
}

/* 历史列表 */
.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  background: rgba(30, 41, 59, 0.6);
  border: 1rpx solid rgba(148, 163, 184, 0.1);
  border-radius: 20rpx;
  padding: 24rpx;
  transition: all 0.2s ease;
}

.history-item:active {
  background: rgba(30, 41, 59, 0.9);
  transform: scale(0.98);
}

.history-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.question-tag {
  width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  color: white;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.history-question {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #f1f5f9;
  line-height: 1.5;
  word-break: break-all;
}

.history-answer {
  background: rgba(15, 23, 42, 0.6);
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.answer-text {
  font-size: 26rpx;
  color: #94a3b8;
  line-height: 1.6;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.history-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.history-time {
  font-size: 22rpx;
  color: #64748b;
}

.continue-btn {
  font-size: 24rpx;
  color: #8b5cf6;
  padding: 8rpx 16rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon-wrap {
  width: 140rpx;
  height: 140rpx;
  background: rgba(30, 41, 59, 0.8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  font-size: 72rpx;
}

.empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #f1f5f9;
  margin-bottom: 12rpx;
}

.empty-desc {
  display: block;
  font-size: 26rpx;
  color: #64748b;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(139, 92, 246, 0.2);
  border-top-color: #8b5cf6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #64748b;
}
