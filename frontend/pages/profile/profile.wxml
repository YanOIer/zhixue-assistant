<view class="container">
  <view class="user-info">
    <view class="avatar-wrapper">
      <open-data type="userAvatarUrl" class="avatar"></open-data>
    </view>
    <view class="nickname">
      <open-data type="userNickName"></open-data>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="viewAIInfo">
      <text class="menu-icon">🤖</text>
      <text class="menu-text">AI系统信息</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="clearHistory">
      <text class="menu-icon">📝</text>
      <text class="menu-text">清空对话历史</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="clearCache">
      <text class="menu-icon">🗑️</text>
      <text class="menu-text">清除缓存</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="about">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <view class="version">版本 1.0.0</view>
</view>
