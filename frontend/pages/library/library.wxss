/** 资料库页面样式 - 深色科技风格 **/

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0f172a 0%, #1e293b 100%);
  padding-bottom: 120rpx;
}

/* 顶部标题栏 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 24rpx;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #f1f5f9;
}

.file-count-badge {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: white;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 50rpx;
}

.header-actions {
  display: flex;
  gap: 16rpx;
}

.action-icon-btn {
  width: 72rpx;
  height: 72rpx;
  background: rgba(30, 41, 59, 0.8);
  border: 1rpx solid rgba(148, 163, 184, 0.1);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #94a3b8;
}

.action-icon-btn:active {
  background: rgba(99, 102, 241, 0.2);
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  margin: 0 32rpx 24rpx;
  background: rgba(30, 41, 59, 0.8);
  border: 1rpx solid rgba(148, 163, 184, 0.1);
  border-radius: 50rpx;
  padding: 20rpx 28rpx;
}

.search-icon {
  font-size: 36rpx;
  color: #64748b;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #f1f5f9;
  height: 40rpx;
}

.search-input::placeholder {
  color: #475569;
}

.search-clear {
  font-size: 28rpx;
  color: #64748b;
  padding: 8rpx;
}

/* 分类标签 */
.category-scroll {
  white-space: nowrap;
  padding: 0 24rpx 24rpx;
}

.category-tabs {
  display: inline-flex;
  gap: 12rpx;
}

.category-tab {
  display: inline-block;
  padding: 14rpx 28rpx;
  background: rgba(30, 41, 59, 0.6);
  border: 1rpx solid rgba(148, 163, 184, 0.1);
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #94a3b8;
  white-space: nowrap;
  transition: all 0.2s ease;
}

.category-tab.active {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-color: transparent;
  color: white;
}

/* 文件列表 */
.file-list {
  padding: 0 24rpx;
}

.file-item {
  display: flex;
  align-items: center;
  background: rgba(30, 41, 59, 0.6);
  border: 1rpx solid rgba(148, 163, 184, 0.1);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s ease;
}

.file-item:active {
  background: rgba(30, 41, 59, 0.9);
  transform: scale(0.98);
}

.file-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.file-icon-wrap.pdf {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
}

.file-icon-wrap.txt, .file-icon-wrap.docx, .file-icon-wrap.md {
  background: linear-gradient(135deg, #22d3ee 0%, #06b6d4 100%);
}

.file-type-icon {
  font-size: 20rpx;
  font-weight: 700;
  color: white;
}

.file-content {
  flex: 1;
  min-width: 0;
}

.file-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #f1f5f9;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.file-meta {
  display: flex;
  align-items: center;
}

.category-tag {
  font-size: 20rpx;
  color: white;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  margin-right: 12rpx;
}

.meta-text {
  font-size: 22rpx;
  color: #64748b;
}

.meta-sep {
  font-size: 22rpx;
  color: #475569;
  margin: 0 8rpx;
}

.file-arrow {
  font-size: 40rpx;
  color: #475569;
  font-weight: 300;
  padding-left: 16rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  background: rgba(30, 41, 59, 0.8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  font-size: 80rpx;
}

.empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #f1f5f9;
  margin-bottom: 12rpx;
}

.empty-desc {
  display: block;
  font-size: 26rpx;
  color: #64748b;
  text-align: center;
}
