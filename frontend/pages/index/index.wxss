/** 首页样式 - 前卫极简科技风 **/

.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #09090b 0%, #18181b 50%, #0c0c0f 100%);
  padding: 24rpx 32rpx;
  padding-bottom: 140rpx;
}

/* 状态指示器 */
.status-bar {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  margin-bottom: 48rpx;
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

.status-bar.online {
  background: rgba(34, 197, 94, 0.12);
  border: 1rpx solid rgba(34, 197, 94, 0.2);
}

.status-bar.offline {
  background: rgba(239, 68, 68, 0.12);
  border: 1rpx solid rgba(239, 68, 68, 0.2);
}

.status-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.status-bar.online .status-dot {
  background: #22c55e;
  box-shadow: 0 0 8rpx #22c55e;
}

.status-bar.offline .status-dot {
  background: #ef4444;
  box-shadow: 0 0 8rpx #ef4444;
}

.status-text {
  font-size: 22rpx;
  letter-spacing: 1rpx;
}

.status-bar.online .status-text {
  color: #22c55e;
}

.status-bar.offline .status-text {
  color: #ef4444;
}

/* 核心区域 */
.hero-section {
  position: relative;
  text-align: center;
  padding: 80rpx 0 60rpx;
  margin-bottom: 48rpx;
}

.hero-glow {
  position: absolute;
  top: 30%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 500rpx;
  height: 300rpx;
  background: radial-gradient(ellipse, rgba(124, 58, 237, 0.25) 0%, rgba(59, 130, 246, 0.15) 40%, transparent 70%);
  filter: blur(80rpx);
}

.hero-title {
  position: relative;
  display: block;
  font-size: 64rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
  background: linear-gradient(135deg, #fafafa 0%, #a78bfa 50%, #60a5fa 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 12rpx;
}

.hero-subtitle {
  position: relative;
  display: block;
  font-size: 26rpx;
  color: #71717a;
  letter-spacing: 3rpx;
}

/* 上传区域 */
.upload-zone {
  background: linear-gradient(145deg, rgba(124, 58, 237, 0.08) 0%, rgba(59, 130, 246, 0.05) 100%);
  border: 1rpx solid rgba(124, 58, 237, 0.2);
  border-radius: 28rpx;
  padding: 52rpx;
  margin-bottom: 48rpx;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.upload-zone::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(124, 58, 237, 0.3), transparent);
}

.upload-zone:active {
  transform: scale(0.985);
  background: linear-gradient(145deg, rgba(124, 58, 237, 0.12) 0%, rgba(59, 130, 246, 0.08) 100%);
}

.upload-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.upload-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #7c3aed 0%, #4f46e5 100%);
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(124, 58, 237, 0.35);
}

.upload-icon {
  font-size: 44rpx;
  color: white;
  font-weight: 300;
}

.upload-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #fafafa;
  margin-bottom: 10rpx;
}

.upload-formats {
  display: block;
  font-size: 24rpx;
  color: #52525b;
  letter-spacing: 1rpx;
}

/* 快捷入口 */
.quick-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 48rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 12rpx;
  background: rgba(24, 24, 27, 0.8);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  transition: all 0.2s ease;
}

.quick-item:active {
  transform: scale(0.95);
}

.quick-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14rpx;
  font-size: 32rpx;
}

.quick-label {
  font-size: 24rpx;
  color: #a1a1aa;
  font-weight: 500;
}

/* 功能特性 */
.features {
  margin-bottom: 48rpx;
}

.section-label {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
  color: #3f3f46;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  margin-bottom: 20rpx;
  padding-left: 4rpx;
}

.feature-list {
  background: rgba(24, 24, 27, 0.6);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.04);
  overflow: hidden;
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-icon {
  font-size: 38rpx;
  margin-right: 20rpx;
  width: 52rpx;
  text-align: center;
}

.feature-content {
  flex: 1;
}

.feature-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #fafafa;
  margin-bottom: 4rpx;
}

.feature-desc {
  display: block;
  font-size: 24rpx;
  color: #52525b;
}

/* 最近文件 */
.recent-section {
  margin-bottom: 48rpx;
}

.recent-list {
  background: rgba(24, 24, 27, 0.6);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.04);
  overflow: hidden;
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
}

.recent-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-icon {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #06b6d4 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18rpx;
  font-size: 28rpx;
}

.recent-info {
  flex: 1;
}

.recent-name {
  display: block;
  font-size: 28rpx;
  color: #fafafa;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recent-meta {
  display: block;
  font-size: 22rpx;
  color: #52525b;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 40rpx 0;
}

.footer-text {
  font-size: 20rpx;
  color: #27272a;
  letter-spacing: 2rpx;
}
