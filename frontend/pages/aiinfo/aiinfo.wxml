<scroll-view scroll-y class="page">

  <!-- 加载状态 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:else>
    <!-- 系统状态卡片 -->
    <view class="status-card">
      <view class="status-glow"></view>
      <text class="status-title">🤖 智学助手 · 系统架构</text>
      <view class="run-mode-badge">
        <text>{{runMode}}</text>
      </view>
      <text class="run-mode-desc">{{runModeDesc}}</text>
    </view>

    <!-- 模块一：文档分类 -->
    <view class="section">
      <view class="section-header">
        <view class="section-icon-wrap" style="background: linear-gradient(135deg, #f472b6 0%, #ec4899 100%)">
          <text>📂</text>
        </view>
        <text class="section-title">文档分类模块</text>
      </view>
      <view class="card">
        <view class="info-row">
          <text class="row-label">分类算法</text>
          <text class="row-value highlight-purple">多项式朴素贝叶斯</text>
        </view>
        <view class="info-row">
          <text class="row-label">特征提取</text>
          <text class="row-value">词袋模型 + TF-IDF</text>
        </view>
        <view class="info-row">
          <text class="row-label">支持学科</text>
          <text class="row-value">数学 / 英语 / 政治 / 计算机 / 其他</text>
        </view>
        <view class="info-row">
          <text class="row-label">运行状态</text>
          <text class="row-status {{classifierStatus === '✅ 已就绪' ? 'online' : 'offline'}}">{{classifierStatus}}</text>
        </view>
        <view class="tip-box">
          <text class="tip-text">上传文档时自动识别学科类别，便于知识管理。</text>
        </view>
      </view>
    </view>

    <!-- 模块二：知识库 -->
    <view class="section">
      <view class="section-header">
        <view class="section-icon-wrap" style="background: linear-gradient(135deg, #22d3ee 0%, #06b6d4 100%)">
          <text>🗄️</text>
        </view>
        <text class="section-title">知识库模块</text>
      </view>
      <view class="card">
        <view class="info-row">
          <text class="row-label">存储方案</text>
          <text class="row-value">SQLite 本地数据库</text>
        </view>
        <view class="info-row">
          <text class="row-label">向量化模型</text>
          <text class="row-value highlight-cyan">BAAI/bge-small-zh</text>
        </view>
        <view class="info-row">
          <text class="row-label">向量索引</text>
          <text class="row-value highlight-cyan">FAISS HNSW</text>
        </view>
        <view class="info-row">
          <text class="row-label">文档数量</text>
          <text class="row-value">{{docCount}} 篇</text>
        </view>
        <view class="info-row">
          <text class="row-label">切片数量</text>
          <text class="row-value">{{chunkCount}} 块</text>
        </view>
      </view>
    </view>

    <!-- 模块三：智能问答 -->
    <view class="section">
      <view class="section-header">
        <view class="section-icon-wrap" style="background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%)">
          <text>💬</text>
        </view>
        <text class="section-title">智能问答模块</text>
      </view>
      <view class="card">
        <!-- 检索流程 -->
        <view class="flow-container">
          <view class="flow-step">
            <view class="step-num">1</view>
            <view class="step-content">
              <text class="step-title">问题向量化</text>
              <text class="step-desc">BAAI/bge-small-zh 编码问题为语义向量</text>
            </view>
          </view>
          <view class="flow-arrow">↓</view>
          <view class="flow-step">
            <view class="step-num">2</view>
            <view class="step-content">
              <text class="step-title">向量检索</text>
              <text class="step-desc">FAISS HNSW 检索 Top-K 相关片段</text>
            </view>
          </view>
          <view class="flow-arrow">↓</view>
          <view class="flow-step">
            <view class="step-num">3</view>
            <view class="step-content">
              <text class="step-title">返回结果</text>
              <text class="step-desc">将相关片段直接返回给用户</text>
            </view>
          </view>
        </view>
        
        <view class="info-row">
          <text class="row-label">检索状态</text>
          <text class="row-status {{ragStatus.indexOf('✅') !== -1 ? 'online' : 'warning'}}">{{ragStatus}}</text>
        </view>
      </view>
    </view>

    <!-- 技术栈 -->
    <view class="section">
      <view class="section-header">
        <view class="section-icon-wrap" style="background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%)">
          <text>🛠️</text>
        </view>
        <text class="section-title">技术栈</text>
      </view>
      <view class="tech-grid">
        <view class="tech-card">
          <text class="tech-layer">前端</text>
          <text class="tech-name">微信小程序</text>
        </view>
        <view class="tech-card">
          <text class="tech-layer">后端</text>
          <text class="tech-name">FastAPI</text>
        </view>
        <view class="tech-card">
          <text class="tech-layer">数据库</text>
          <text class="tech-name">SQLite</text>
        </view>
        <view class="tech-card">
          <text class="tech-layer">向量模型</text>
          <text class="tech-name">BGE-small-zh</text>
        </view>
        <view class="tech-card">
          <text class="tech-layer">向量索引</text>
          <text class="tech-name">FAISS HNSW</text>
        </view>
        <view class="tech-card">
          <text class="tech-layer">运行环境</text>
          <text class="tech-name">CPU</text>
        </view>
      </view>
    </view>

    <!-- 底部 -->
    <view class="footer">
      <text class="footer-text">智学助手 v1.1.0</text>
    </view>
  </block>
</scroll-view>
