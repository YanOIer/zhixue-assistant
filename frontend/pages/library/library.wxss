.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.search-bar {
  background: white;
  border-radius: 40rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
}

.search-input {
  font-size: 28rpx;
}

.file-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.file-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  width: calc(50% - 10rpx);
  box-sizing: border-box;
  text-align: center;
}

.file-icon {
  font-size: 80rpx;
  display: block;
}

.file-name {
  font-size: 28rpx;
  color: #333;
  margin-top: 15rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.file-meta {
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-top: 20rpx;
  display: block;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}
