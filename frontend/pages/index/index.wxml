<view class="container">
  <view class="header">
    <text class="title">智学助手</text>
    <text class="subtitle">基于AI的智能学习资料管理</text>
  </view>
  
  <view class="upload-section">
    <view class="upload-btn" bindtap="chooseFile">
      <text class="upload-icon">+</text>
      <text class="upload-text">上传学习资料</text>
      <text class="upload-hint">支持 PDF / 图片 / 文字</text>
    </view>
  </view>
  
  <view class="quick-actions">
    <view class="action-item" bindtap="goToLibrary">
      <text class="action-icon">📚</text>
      <text class="action-text">我的资料库</text>
    </view>
    <view class="action-item" bindtap="goToChat">
      <text class="action-icon">💬</text>
      <text class="action-text">开始提问</text>
    </view>
  </view>
  
  <view class="recent-section" wx:if="{{recentFiles.length > 0}}">
    <text class="section-title">最近上传</text>
    <view class="file-list">
      <view class="file-item" wx:for="{{recentFiles}}" wx:key="id">
        <text class="file-icon">📄</text>
        <view class="file-info">
          <text class="file-name">{{item.name}}</text>
          <text class="file-time">{{item.time}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
