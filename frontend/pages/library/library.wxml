<view class="container">
  <!-- 顶部标题栏 -->
  <view class="header">
    <view class="header-left">
      <text class="header-title">我的资料库</text>
      <view class="file-count-badge">{{files.length}}</view>
    </view>
    <view class="header-actions">
      <view class="action-icon-btn" bindtap="refreshFiles">
        <text>↻</text>
      </view>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <text class="search-icon">⌕</text>
    <input class="search-input" placeholder="搜索资料..." bindinput="onSearch" value="{{searchKeyword}}" />
    <text class="search-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">✕</text>
  </view>

  <!-- 分类标签 -->
  <scroll-view class="category-scroll" scroll-x="true">
    <view class="category-tabs">
      <view class="category-tab {{currentCategory === '全部' ? 'active' : ''}}" bindtap="filterByCategory" data-category="全部">
        <text>全部</text>
      </view>
      <view class="category-tab {{currentCategory === '数学' ? 'active' : ''}}" bindtap="filterByCategory" data-category="数学">
        <text>📐 数学</text>
      </view>
      <view class="category-tab {{currentCategory === '英语' ? 'active' : ''}}" bindtap="filterByCategory" data-category="英语">
        <text>🔤 英语</text>
      </view>
      <view class="category-tab {{currentCategory === '政治' ? 'active' : ''}}" bindtap="filterByCategory" data-category="政治">
        <text>📜 政治</text>
      </view>
      <view class="category-tab {{currentCategory === '计算机' ? 'active' : ''}}" bindtap="filterByCategory" data-category="计算机">
        <text>💻 计算机</text>
      </view>
      <view class="category-tab {{currentCategory === '其他' ? 'active' : ''}}" bindtap="filterByCategory" data-category="其他">
        <text>📂 其他</text>
      </view>
    </view>
  </scroll-view>

  <!-- 文件列表 -->
  <view class="file-list" wx:if="{{files.length > 0}}">
    <view class="file-item" wx:for="{{files}}" wx:key="id" bindtap="viewFile" data-id="{{item.id}}">
      <view class="file-icon-wrap {{item.type}}">
        <text class="file-type-icon">{{item.type === 'pdf' ? 'PDF' : 'TXT'}}</text>
      </view>
      <view class="file-content">
        <text class="file-name">{{item.name}}</text>
        <view class="file-meta">
          <view class="category-tag">{{item.category}}</view>
          <text class="meta-text">{{item.size}}</text>
          <text class="meta-sep">·</text>
          <text class="meta-text">{{item.time}}</text>
        </view>
      </view>
      <view class="file-arrow">›</view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{files.length === 0}}">
    <view class="empty-icon-wrap">
      <text>📂</text>
    </view>
    <text class="empty-title">{{searchKeyword || currentCategory !== '全部' ? '没有找到匹配的文件' : '资料库为空'}}</text>
    <text class="empty-desc">{{searchKeyword || currentCategory !== '全部' ? '试试其他关键词或分类' : '点击首页上传按钮添加资料'}}</text>
  </view>
</view>
