.container {
  padding: 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.clear-btn {
  font-size: 28rpx;
  color: #ff4444;
  padding: 10rpx 20rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 15rpx;
}

.history-question {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  margin-right: 20rpx;
  word-break: break-all;
}

.history-time {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

.history-answer {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 15rpx;
}

.answer-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  display: block;
}

.history-footer {
  display: flex;
  justify-content: flex-end;
}

.continue-btn {
  font-size: 26rpx;
  color: #4A90E2;
  padding: 10rpx 20rpx;
}

.empty-state {
  text-align: center;
  padding: 150rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 36rpx;
  color: #666;
  display: block;
  margin-bottom: 15rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #999;
  display: block;
}

.loading-state {
  text-align: center;
  padding: 100rpx;
}

.loading-text {
  font-size: 30rpx;
  color: #999;
}
