/** 我的页面样式 - 深色科技风格 **/

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #0f172a 0%, #1e293b 100%);
  padding: 24rpx 32rpx;
  padding-bottom: 160rpx;
}

/* 用户卡片 */
.user-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  margin-bottom: 40rpx;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(99, 102, 241, 0.4);
}

.user-avatar text {
  font-size: 72rpx;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #f1f5f9;
  margin-bottom: 8rpx;
}

.user-desc {
  display: block;
  font-size: 26rpx;
  color: #64748b;
}

/* 菜单区域 */
.menu-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.menu-group {
  background: rgba(30, 41, 59, 0.6);
  border: 1rpx solid rgba(148, 163, 184, 0.1);
  border-radius: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.1);
  transition: background 0.2s ease;
}

.menu-item:active {
  background: rgba(99, 102, 241, 0.1);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.menu-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 32rpx;
}

.menu-info {
  flex: 1;
  min-width: 0;
}

.menu-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #f1f5f9;
}

.menu-value {
  display: block;
  font-size: 22rpx;
  color: #64748b;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-arrow {
  font-size: 36rpx;
  color: #475569;
  font-weight: 300;
  padding-left: 16rpx;
}

/* 版本信息 */
.version-info {
  position: fixed;
  bottom: 40rpx;
  left: 0;
  right: 0;
  text-align: center;
}

.version-text {
  font-size: 22rpx;
  color: #475569;
}
