.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.search-bar {
  background: white;
  border-radius: 40rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
}

/* 上传区域 */
.upload-section {
  margin-bottom: 20rpx;
}

.upload-btn-small {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 40rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
}

.upload-icon-small {
  font-size: 40rpx;
  margin-right: 10rpx;
}

.upload-text-small {
  font-size: 28rpx;
}

.search-input {
  font-size: 28rpx;
}

.file-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.file-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  width: calc(50% - 10rpx);
  box-sizing: border-box;
  text-align: center;
}

.file-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 10rpx;
}

.file-category {
  font-size: 24rpx;
  color: white;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  display: inline-block;
  margin-bottom: 10rpx;
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}

.file-name {
  font-size: 28rpx;
  color: #333;
  margin-top: 15rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.file-meta {
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-top: 20rpx;
  display: block;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}
