/** 对话页面样式 - 深色科技风格 **/

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #0f172a 0%, #1e293b 100%);
}

/* 清空按钮 */
.clear-btn {
  position: fixed;
  top: 20rpx;
  right: 24rpx;
  width: 72rpx;
  height: 72rpx;
  background: rgba(30, 41, 59, 0.9);
  border: 1rpx solid rgba(148, 163, 184, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  z-index: 100;
}

/* 消息滚动区域 */
.chat-scroll {
  flex: 1;
  padding: 24rpx;
  padding-bottom: 140rpx;
}

.message-list {
  display: flex;
  flex-direction: column;
}

/* 消息样式 */
.message {
  display: flex;
  margin-bottom: 32rpx;
  align-items: flex-start;
}

.message.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(30, 41, 59, 0.8);
  border: 1rpx solid rgba(148, 163, 184, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.message.user .avatar {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border: none;
}

.bubble {
  max-width: 75%;
  margin: 0 20rpx;
  background: rgba(30, 41, 59, 0.8);
  border: 1rpx solid rgba(148, 163, 184, 0.1);
  border-radius: 24rpx;
  border-bottom-left-radius: 8rpx;
  padding: 24rpx;
  position: relative;
}

.message.user .bubble {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border: none;
  border-bottom-left-radius: 24rpx;
  border-bottom-right-radius: 8rpx;
}

.msg-text {
  font-size: 30rpx;
  line-height: 1.7;
  color: #f1f5f9;
  word-break: break-all;
}

/* 模式标签 */
.mode-tag {
  display: inline-block;
  margin-top: 16rpx;
  padding: 8rpx 16rpx;
  background: rgba(99, 102, 241, 0.2);
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #a5b4fc;
}

/* 来源 */
.sources {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(148, 163, 184, 0.1);
}

.sources-label {
  display: block;
  font-size: 22rpx;
  color: #64748b;
  margin-bottom: 10rpx;
}

.source-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.source-tag {
  font-size: 22rpx;
  color: #22d3ee;
  background: rgba(34, 211, 238, 0.1);
  padding: 6rpx 14rpx;
  border-radius: 10rpx;
}

/* 加载动画 */
.loading-bubble {
  padding: 28rpx 36rpx;
}

.loading-dots {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background: #64748b;
  border-radius: 50%;
  animation: pulse 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes pulse {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

/* 输入区域 */
.input-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(15, 23, 42, 0.95);
  border-top: 1rpx solid rgba(148, 163, 184, 0.1);
}

.msg-input {
  flex: 1;
  background: rgba(30, 41, 59, 0.8);
  border: 1rpx solid rgba(148, 163, 184, 0.1);
  border-radius: 50rpx;
  padding: 22rpx 32rpx;
  font-size: 30rpx;
  color: #f1f5f9;
}

.msg-input::placeholder {
  color: #475569;
}

.send-btn {
  width: 88rpx;
  height: 88rpx;
  background: rgba(30, 41, 59, 0.8);
  border: 1rpx solid rgba(148, 163, 184, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
}

.send-btn.active {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border: none;
}

.send-icon {
  font-size: 36rpx;
  color: #64748b;
  font-weight: 600;
}

.send-btn.active .send-icon {
  color: white;
}

.send-btn[disabled] {
  opacity: 0.5;
}
