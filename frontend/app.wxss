/** 全局样式 - 现代科技风格 **/
page {
  --primary: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  --primary-solid: #6366f1;
  --accent: #22d3ee;
  --bg-primary: #0f172a;
  --bg-secondary: #1e293b;
  --bg-card: #1e293b;
  --text-primary: #f1f5f9;
  --text-secondary: #94a3b8;
  --text-muted: #64748b;
  --border: rgba(148, 163, 184, 0.1);
  --shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.3);
}

.container {
  padding: 30rpx;
  background: var(--bg-primary);
  min-height: 100vh;
}
