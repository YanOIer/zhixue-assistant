.page {
  background: #f0f4f8;
  min-height: 100vh;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}
.loading-text {
  color: #999;
  font-size: 30rpx;
}

/* Banner */
.banner {
  background: linear-gradient(135deg, #4A90E2, #357abd);
  padding: 48rpx 40rpx 36rpx;
  color: white;
}
.banner-title {
  display: block;
  font-size: 38rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}
.run-mode-badge {
  display: inline-block;
  background: rgba(255,255,255,0.25);
  border-radius: 30rpx;
  padding: 8rpx 24rpx;
  margin-bottom: 16rpx;
}
.run-mode-text {
  font-size: 26rpx;
  color: white;
  font-weight: 600;
}
.run-mode-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  line-height: 1.6;
}

/* Section */
.section {
  padding: 0 24rpx;
  margin-top: 32rpx;
}
.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.section-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

/* Card */
.card {
  background: white;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.07);
}

/* Row */
.row {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.row:last-child {
  border-bottom: none;
}
.label {
  font-size: 26rpx;
  color: #888;
  width: 160rpx;
  flex-shrink: 0;
  padding-top: 2rpx;
}
.value {
  font-size: 27rpx;
  color: #333;
  flex: 1;
  line-height: 1.5;
}
.highlight-blue {
  color: #4A90E2;
  font-weight: 500;
}
.highlight-green {
  color: #28a745;
  font-weight: 500;
}

/* Tip Box */
.tip-box {
  background: #f8f9ff;
  border-left: 6rpx solid #4A90E2;
  border-radius: 0 12rpx 12rpx 0;
  padding: 16rpx 20rpx;
  margin-top: 24rpx;
}
.tip-text {
  font-size: 24rpx;
  color: #555;
  line-height: 1.7;
}

/* Flow Steps */
.flow-steps {
  padding: 8rpx 0;
}
.step {
  display: flex;
  align-items: flex-start;
  background: #f8fbff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 4rpx;
}
.step-num {
  width: 48rpx;
  height: 48rpx;
  background: #4A90E2;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.step-num text {
  color: white;
  font-size: 26rpx;
  font-weight: bold;
}
.step-body {
  flex: 1;
}
.step-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}
.step-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}
.step-arrow {
  text-align: center;
  color: #4A90E2;
  font-size: 28rpx;
  padding: 8rpx 0;
}

/* Tech Grid */
.tech-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.tech-item {
  width: calc(50% - 8rpx);
  background: #f8f9ff;
  border-radius: 16rpx;
  padding: 20rpx 22rpx;
  box-sizing: border-box;
}
.tech-layer {
  display: block;
  font-size: 22rpx;
  color: #4A90E2;
  font-weight: 600;
  margin-bottom: 6rpx;
}
.tech-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}
.tech-detail {
  display: block;
  font-size: 22rpx;
  color: #888;
}

/* Footer */
.footer {
  text-align: center;
  padding: 48rpx 0 60rpx;
}
.footer-text {
  font-size: 24rpx;
  color: #bbb;
}
